# ===========================================
# AODI Website - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL connection string
# For Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# For Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# For PlanetScale: Use their connection string format
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ===========================================
# AUTHENTICATION & SECURITY (Required)
# ===========================================
# Secret for signing admin session cookies (generate a random 32+ character string)
# You can generate one with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here-at-least-32-characters

# Master password for admin account recovery via /api/admin/reset-admin
# This is used as a backup to reset admin passwords
ADMIN_PASSWORD=your-secure-master-password-here

# ===========================================
# SPAM PROTECTION - hCaptcha (Recommended)
# ===========================================
# Get your keys from https://www.hcaptcha.com/
# Site key is public (used in frontend)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
# Secret key is private (used in API routes)
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# ===========================================
# PAYMENT PROCESSING (Optional)
# ===========================================
# Paystack - Get keys from https://dashboard.paystack.com/
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# PayPal - Get keys from https://developer.paypal.com/
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ===========================================
# EMAIL SERVICE (Optional - for password reset emails)
# ===========================================
# SendGrid - Get API key from https://app.sendgrid.com/
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@africaofourdreaminitiative.org

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# Google Analytics 4 - Get from https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# ERROR MONITORING (Optional)
# ===========================================
# Sentry - Get DSN from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===========================================
# APPLICATION SETTINGS (Optional)
# ===========================================
# Base URL of your application (used for generating absolute URLs)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Node environment
NODE_ENV=production
